# GitHub PR Auto-Reviewer — 認証情報 / 設定

# GitHub Personal Access Token
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Signal 通知先
SIGNAL_RECIPIENT=+81xxxxxxxxxx

# GitHub ログイン名
GITHUB_LOGIN=your-github-login

# バイナリパス
CLAUDE_PATH=/Users/you/.local/bin/claude
GH_BIN=/opt/homebrew/bin/gh
OPENCLAW_BIN=/Users/you/.npm-global/bin/openclaw

# ファイルパス（プロジェクトルートからの相対パス）
PR_REVIEW_SH=./review-pr.sh
SETTINGS_TEMPLATE=./.claude-settings-template.json

# Webhook 設定
WEBHOOK_SECRET=your-webhook-secret-run-openssl-rand-hex-32
SMEE_URL=https://smee.io/your-channel-id
PORT=3456
TRIGGER_KEYWORD=@ClaudeReview
LOG_DIR=./logs
